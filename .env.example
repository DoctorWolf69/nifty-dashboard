# Kite Connect (Zerodha) — required
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# NIFTY F&O commission gate (paper signals)
NIFTY_LOT_SIZE=65
NIFTY_BROKERAGE_PER_ORDER=20
NIFTY_BROKERAGE_PCT_CAP=0.0003
NIFTY_MIN_NET_PROFIT_MULTIPLE=3
NIFTY_MIN_GROSS_RUPEES=500

# Daily EOD report email (optional — leave blank to disable the 20:15 send)
# REPORT_EMAIL_FROM / _APP_PASSWORD use a Gmail address + 16-char App Password
# (Google account -> Security -> App passwords). TO + CC all get ONE shared email.
REPORT_EMAIL_FROM=
REPORT_EMAIL_APP_PASSWORD=
REPORT_EMAIL_TO=you@gmail.com,partner@gmail.com
REPORT_EMAIL_CC=mentor@example.com,friend@example.com
REPORT_SMTP_HOST=smtp.gmail.com
REPORT_SMTP_PORT=465
# Public HTTPS base for the static reports (so the email links to the live page)
REPORT_PUBLIC_URL=https://your-domain.example/reports

# Normalized OI-velocity thresholds (z-score on context-normalized ΔOI velocity).
# Tune with: python -m nifty.replay.calibrate_oiv  (distribution guide), then
# rebuild a day's replay and check the signal count. Defaults are sensible.
OIV_Z_ALERT=1.5        # adding z to raise an abnormal-OI alert
OIV_PCT_ALERT=90       # or velocity percentile
OIV_Z_DIM=1.5          # confluence oi_velocity dimension pass
OIV_PCT_DIM=90
OIV_Z_UNWIND=1.5       # gamma-blast unwind (abs z)
OIV_OI_PCTL_HEAVY=70   # gamma heavy-OI percentile
OIV_ATR_REF=110        # reference NIFTY ATR(14) pts/day for the volatility factor
OIV_BLEND_HIST=0.6     # weight on archive-derived baseline vs in-session adaptive
