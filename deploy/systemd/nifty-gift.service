[Unit]
Description=GIFT Nifty overnight monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__APPDIR__
Environment=TZ=Asia/Kolkata
ExecStart=__APPDIR__/.venv/bin/python -m nifty.sources.gift_monitor --poll-seconds 60 --only-when-open --print
Restart=on-failure
RestartSec=10
