[Unit]
Description=NIFTY NSE EOD download (cm)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=__USER__
WorkingDirectory=__APPDIR__
Environment=TZ=Asia/Kolkata
ExecStart=__APPDIR__/.venv/bin/python -m nifty.jobs eod --targets equity_bhavcopy,delivery_report,mkt_activity_report
